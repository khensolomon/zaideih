{
  "name": "zaideih",
  "version": "26.4.4",
  "description": "Zaideih Music Station",
  "keywords": [
    "zaideih",
    "music"
  ],
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "concurrently \"npm run dev\" \"npm run django\"",
    "dev": "vite --config ./assets/com/vite.js",
    "build": "vite build --config ./assets/com/vite.js",
    "dev-watch": "vite build --watch --config ./assets/com/vite.js",
    "django:linux": "./venv/bin/python manage.py runserver",
    "django:win": ".\\venv\\Scripts\\python manage.py runserver",
    "django": "if [ -f \"./venv/bin/python\" ]; then ./venv/bin/python manage.py runserver; else .\\venv\\Scripts\\python manage.py runserver; fi"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.8"
  },
  "homepage": "https://github.com/khensolomon/zaideih#readme",
  "bugs": {
    "url": "https://github.com/khensolomon/zaideih/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/zaideih.git"
  },
  "license": "MIT",
  "author": "Khen Solomon Lethil"
}
