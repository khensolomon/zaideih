{
  "name": "zaideih",
  "version": "1.2.1",
  "description": "Zaideih Music Station",
  "live": "https://www.zaideih.com",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "node webpack.build.js",
    "serve": "node serve.js",
    "task": "node task.js",
    "start": "node serve.js",
    "test-port": "set PORT=5000 && node serve",
    "test-listen": "set LISTEN= && node serve",
    "test-production": "set NODE_ENV=production && node serve",
    "pm2:start": "pm2 start",
    "pm2:startJSON": "pm2 start pm2.json",
    "pm2:reload": "pm2 reload Zaideih",
    "pm2:reloadJSON": "pm2 reload pm2.json",
    "pm2:stop": "pm2 stop Zaideih",
    "pm2:delete": "pm2 delete Zaideih",
    "pm2:kill": "pm2 kill",
    "pm2:list": "pm2 list"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ],
    "plugins": []
  },
  "dependencies": {
    "@google-cloud/storage": "^6.9.0",
    "lethil": "^1.2.9",
    "mysql2": "^3.0.0",
    "pug": "^3.0.2",
    "tar": "^6.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "axios": "^1.2.2",
    "babel-loader": "^9.1.2",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.7.3",
    "file-loader": "^6.2.0",
    "get-mp3-duration": "^1.0.0",
    "jsdom": "^21.0.0",
    "mini-css-extract-plugin": "^2.7.2",
    "node-id3": "^0.2.5",
    "pinia": "^2.0.28",
    "postcss-loader": "^7.0.2",
    "sass": "^1.57.1",
    "sass-loader": "^13.2.0",
    "script-loader": "^0.7.2",
    "style-loader": "^3.3.1",
    "url-loader": "^4.1.1",
    "vue": "^3.2.45",
    "vue-loader": "^17.0.1",
    "vue-resource": "^1.5.3",
    "vue-router": "^4.1.6",
    "vue-template-compiler": "^2.7.14",
    "webpack": "^5.75.0",
    "webpack-dev-middleware": "^6.0.1",
    "webpack-hot-middleware": "^2.25.3",
    "webpack-merge": "^5.8.0"
  },
  "docs": {
    "dev": {
      "lethil": "file:../lethil"
    },
    "used-in": {
      "m3s": [
        "jsdom"
      ],
      "id3": [
        "get-mp3-duration",
        "node-id3",
        "music-metadata"
      ],
      "test": [
        "siege"
      ],
      "?": [
        "parse5"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/zaideih.git"
  },
  "author": "Khen Solomon Lethil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/khensolomon/zaideih/issues"
  },
  "homepage": "https://github.com/khensolomon/zaideih#readme"
}
