{
  "name": "zaideih",
  "version": "1.3.0",
  "description": "Zaideih Music Station",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "node webpack.build.js",
    "serve": "node serve.js",
    "task": "node task.js",
    "start": "node serve.js",
    "test": "mocha ./test/*.js",
    "test-port": "set PORT=5000 && node serve",
    "test-listen": "set LISTEN= && node serve",
    "test-production": "set NODE_ENV=production && node serve",
    "pm2:setup": "pm2 deploy ecosystem.json production setup",
    "pm2:deploy": "pm2 deploy ecosystem.json production",
    "deployment:environment": "node run environment",
    "deployment:ecosystem": "node run ecosystem",
    "pm2:start": "pm2 start",
    "pm2:startJSON": "pm2 start ecosystem.json",
    "pm2:reload": "pm2 reload Zaideih",
    "pm2:reloadJSON": "pm2 reload ecosystem.json",
    "pm2:stop": "pm2 stop Zaideih",
    "pm2:delete": "pm2 delete Zaideih",
    "pm2:kill": "pm2 kill",
    "pm2:list": "pm2 list"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ],
    "plugins": []
  },
  "dependencies": {
    "@google-cloud/storage": "^6.9.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "helmet": "^6.1.5",
    "lethil": "^1.3.4",
    "mysql2": "^3.2.3",
    "pug": "^3.0.2",
    "tar": "^6.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "axios": "^1.3.5",
    "babel-loader": "^9.1.2",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.7.3",
    "file-loader": "^6.2.0",
    "get-mp3-duration": "^1.0.0",
    "jsdom": "^21.1.1",
    "mini-css-extract-plugin": "^2.7.5",
    "mocha": "^10.2.0",
    "node-id3": "^0.2.6",
    "pinia": "^2.0.34",
    "postcss-loader": "^7.2.4",
    "sass": "^1.62.0",
    "sass-loader": "^13.2.2",
    "script-loader": "^0.7.2",
    "style-loader": "^3.3.2",
    "url-loader": "^4.1.1",
    "vue": "^3.2.47",
    "vue-loader": "^17.0.1",
    "vue-resource": "^1.5.3",
    "vue-router": "^4.1.6",
    "vue-template-compiler": "^2.7.14",
    "webpack": "^5.79.0",
    "webpack-dev-middleware": "^6.0.2",
    "webpack-hot-middleware": "^2.25.3",
    "webpack-merge": "^5.8.0"
  },
  "docs": {
    "dev": {
      "lethil": "file:../lethil"
    },
    "used-in": {
      "m3s": [
        "jsdom"
      ],
      "id3": [
        "get-mp3-duration",
        "node-id3",
        "music-metadata"
      ],
      "test": [
        "siege"
      ],
      "?": [
        "parse5"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/zaideih.git"
  },
