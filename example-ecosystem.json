{
  "apps": [
    {
      "name": "<APP_NAME>",
      "script": "./serve.js",
      "watch": false,
      "ignore_watch": [],
      "error_file": "./logs/pm2.err.log",
      "out_file": "./logs/pm2.out.log",
      "-instances": 1,
      "-exec_mode": "cluster",
      "autorestart": true,
      "max_memory_restart": "300M",
      "env": {
        "NODE_ENV": "production"
      },
      "env_production": {
        "NODE_ENV": "production"
      },
      "env_development": {
        "NODE_ENV": "development"
      },
      "cwd": "/var/www/<APP_REPO>-src/current",
      "args": ""
    }
  ],
  "deploy": {
    "production": {
      "user": "<SSH_USER>",
      "host": "<SSH_HOST>",
      "ref": "origin/master",
      "repo": "git@github.com:khensolomon/<APP_REPO>.git",
      "fetch": "all",
      "path": "/var/www/<APP_REPO>-src",
      "post-deploy-help": {
        "wid": "Execute command after git:ref.fetch",
        "eg": "npm install && npm run build && pm2 reload ecosystem.json --env production"
      },
      "pre-deploy": "",
      "post-deploy": "",
      "pre-setup": "",
      "post-setup": "",
      "pre-deploy-local": ""
    }
  },
  "help": {
    "define": {
      "APP_NAME": "Application name",
      "APP_REPO": "Repository name",
      "SSH_USER": "SSH user",
      "SSH_HOST": "SSH host"
    },
    "^env_*$": "Specify environment variables to be injected when using --env",
    "deploy.production.setup": "pm2 deploy ecosystem.json production setup",
    "deploy.production.update": "pm2 deploy ecosystem.json production",
    "deploy.development.local": "pm2 start ecosystem.json --env development"
  }
}