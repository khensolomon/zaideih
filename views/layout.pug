    script(src='https://cdn.jsdelivr.net/npm/vue@3.2.45')
    //- script(src='https://cdn.jsdelivr.net/npm/vue-resource@1.5.3')
    script(src='https://cdn.jsdelivr.net/npm/vue-router@4.1.6')


  body.page
    //- Google Tag Manager (noscript)
    noscript
      iframe(src='https://www.googletagmanager.com/ns.html?id=GTM-PBZSB96' height=0 width=0 style='display:none;visibility:hidden')
    block content
    script(type='text/javascript', src='/script.js?v='+appVersion)
    link(rel='stylesheet', href='/style.css?v='+appVersion)