doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name='robots' content='index, follow')
    meta(name="theme-color" content="#5a5a5a")

    meta(name="apple-mobile-web-app-capable" content="yes")
    meta(name="apple-mobile-web-app-status-bar-style" content="black-translucent")
    meta(name="apple-mobile-web-app-title" content=appName)

    if title
      title= title
    if keywords
      meta(name="keywords" content=keywords)
    if description
      meta(name="description" content=description data-env=environment)
    meta(name="application-name" content=appName data-version=appVersion data-album=raw.album data-artist=raw.artist data-genre=raw.genre data-lang=raw.lang)
    base(href='/')
    link(rel='api', href='api')
    //- link(rel='icon', href='favicon.png' type='image/png')
    link(rel="apple-touch-icon", sizes="180x180" href="/apple-touch-icon.png")
    link(rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png")
    link(rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png")
    link(rel="manifest" href="/app.webmanifest")

    //- Google tag (gtag.js
    script(async src='https://www.googletagmanager.com/gtag/js?id=G-65TTKMZEGC')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-65TTKMZEGC');

