# ~/dev/notes/scripts/env.sh ./origin.env
# origin.env
# cp origin.env .env
# In development, set DEBUG to True. In production, this should be False or unset.
DEBUG             = false # can be overridden by environment variable in production
APP_NAME          = <project>
APP_PORT          = 3010
# APP_HOST        = ?
ALLOWED_HOSTS     = *

# Storage Configuration
# Local eg: ./data/storage
# Production eg: /opt/bucket/storage
STORAGE_ROOT      = /<bucket>/storage
MEDIA_DIR         = /<bucket>/media
CACHE_DIR         = /<bucket>/storage/<project>/cache
STORE_DIR         = /<bucket>/storage/<project>/store

DB_NAME           = <project>
DB_USER           = <db_user> # Change "root" to your actual database username
DB_PWD            = <db_password>
DB_ROOT_PWD       = <db_password>
DB_HOST           = <db_host> # Change "db" to "localhost" for docker-compose
DB_PORT           = 3306
# DB backup and restore points to /docker-entrypoint-initdb.d in the MySQL container, which is mapped to ${DB_DIR} on the host
# ${STORAGE_ROOT}/${APP_NAME}/mysql
DB_DIR            = /<bucket>/storage/<project>/mysql

# NOTE: custom
REPO_OWNER        = khensolomon
# Get it from python manage.py generate_secret_key
# python -c 'import secrets; print(secrets.token_urlsafe(20))'
SECRET_KEY        = unique-and-secret-key-for-deployment
APP_SECRET_SHARED = unique-and-secret-shared-with-worker
# Buckket name and credentials for S3-compatible storage 
# (e.g., Google, MinIO, DigitalOcean Spaces)
BUCKETNAME      = storage.lethil.me
BUCKETCRED      = /<bucket>/storage/access/gsaks.json

# Where the Worker lives. Must be reachable from Django.
WORKER_URL      = "https://api.example.com"

# NOTE: development
SSH_USER        = <ssh_user>
SSH_HOST        = <ssh_host>
GOOGLE_APPLICATION_CREDENTIALS = /<bucket>/storage/access/gsaks.json
MYSQL_ROOT_PASSWORD=<db_password> # Only needed for local development, on production Github Actions will set this as an environment variable and it won't be used in the .env file.