listen = host:localhost;port:8081
# listen = host:0.0.0.0;port:8081

# ; NOTE: Bucket name
bucket = storage.lethil.me

# ; NOTE: storage
storage = /var/www/storage
media = /var/www/media

# ; NOTE: MySQL
mysqlConnection = mysql://root@localhost/zaideih?flags=-FOUND_ROWS
# mysqlConnection = mysql://user@host/zaideih?flags=-FOUND_ROWS
# mysqlConnection = mysql://user:pwd@host/databaseName?flags=-FOUND_ROWS
# mysqlConnection = mysql://user:pwd@host/databaseName?debug=true&charset=BIG5_CHINESE_CI&timezone=-0700

# ; NOTE: Mongodb
# mongoConnection = mongodb://localhost:27017/zaideih

# NOTE: individual
# restrict = /api:restrictMiddleWare
# referer = zaideih.*
# restrict = /api:restrictMiddleWare
restrict = d1v:l1;i1o:i1;a1n:a1;w1b:w1
referer = locahost.local;example.com;localhost:8081

# PM2 ecosystem.json values
# pm2 app name
# APP_NAME = zaideih
# pm2 app folder
# APP_SRC = zaideih
# pm2 deploy repo
# APP_REPO = git@github.com:<user>/<repo>.git
# pm2 deploy user
# SSH_USER = khensolomon
# pm2 deploy host
# SSH_HOST = 127.0.0.1

