# origin.env  —  cp origin.env .env, fill in real values, then:  python3 secrets.py --push
#
# This file is sorted by DESTINATION, not by topic. Every value belongs to
# exactly one of three zones, split by "#@" markers. The zone decides where
# the value ends up after the GitHub hop:
#
#   (bundle, above the first marker)   APP CONFIG
#       → pushed as ONE secret, ENV_BASE
#       → merged into /opt/<app>/.env on the server  → read by Django + compose
#       → this is the ONLY zone that lands in the production .env
#
#   #@ individual                      DEPLOYMENT SECRETS
#       → each pushed as its OWN GitHub secret (the names deploy.yml reads
#         directly as ${{ secrets.NAME }})
#       → consumed by workflow STEPS (ssh, tunnel, runner check, GHCR cleanup)
#       → NEVER written to the server .env. The server never needs them;
#         only the runner reaching the server does.
#
#   #@ local                           LOCAL / DEV ONLY
#       → never pushed anywhere. Read by secrets.py (repo identity) or used
#         only when running the app on your own machine.
#
# Rule of thumb: "Does Django or docker-compose need this value ON the box?"
#   yes → bundle.   "Does only the CI runner need it to REACH the box?" → individual.


# ════════════════════════════════════════════════════════════════════════════
#  APP CONFIG  →  ENV_BASE  →  server .env  (Django + compose runtime)
# ════════════════════════════════════════════════════════════════════════════

# In development set DEBUG=True. In production this should be False or unset.
DEBUG                   = false # may be overridden per-environment via VAR_BASE/ENV_OVERRIDES
APP_NAME                = zaideih
APP_PORT                = 3010
# APP_HOST              = ?
ALLOWED_HOSTS           = *

# Storage paths. NOTE: also read by the deploy step (it mkdir's these on the
# host) — but they live here because Django/compose need them on the box too.
# <bucket> can be eg. /opt/bucket
STORAGE_ROOT            = ${BUCKET}/storage
MEDIA_ROOT              = ${BUCKET}/media
STORE_DIR               = ${STORAGE_ROOT}/${APP_NAME}/store
CACHE_DIR               = ${STORAGE_ROOT}/${APP_NAME}/cache

# Database. DB_HOST must be the compose service name ("db") in swarm — never
# "localhost" (the build-env merge action rejects DB_HOST=localhost outright).
DB_NAME                 = ${APP_NAME}
DB_USER                 = @core
DB_PWD                  = @core
DB_ROOT_PWD             = @core
DB_HOST                 = @core
DB_PORT                 = @core
# DB backup and restore points to /docker-entrypoint-initdb.d in the MySQL container, which is mapped to ${DB_DIR} on the host
DB_DIR                  = ${STORAGE_ROOT}/${APP_NAME}/mysql

# App secrets (encrypted: ENV_BASE is a GitHub Secret, so these stay sealed)
# python -c 'import secrets; print(secrets.token_urlsafe(20))'
SECRET_KEY              = unique-and-secret-key-for-deployment
APP_SECRET_SHARED       = unique-and-secret-shared-with-worker

# Object storage the app reads at runtime (R2 / GCS)
STORAGE_BACKEND         = r2
GCS_BUCKETNAME          = @core
GCS_SECRET              = ${STORAGE_ROOT}/access/gsaks.json
CF_ACCOUNT_ID           = @core
R2_BUCKETNAME           = @core
R2_ACCESS_KEY_ID        = @core
R2_ACCESS_SECRET        = @core

# Worker the app talks to. Must be reachable from Django.
WORKER_URL              = "https://media.${APP_NAME}.com"

# NOTE: special (MyOrdbok-specific)
# SPEECH_URL            = ?
# NLTK_DATA             = ?

#@ individual
# ════════════════════════════════════════════════════════════════════════════
#  DEPLOYMENT SECRETS  →  one GitHub secret each  →  CI steps only (never the server .env)
# ════════════════════════════════════════════════════════════════════════════
# These mirror the deployment secrets in the CORE repo's .env on purpose:
# core (lethil) provisions the server, this app (zaideih) deploys to it, and
# they are separate GitHub repos with separate secret stores — so the same
# server-reaching credentials legitimately exist in both. Not duplication to
# de-dupe; each repo owns its own copy.

# SSH deploy target (used by the ssh path + the failure-log step in deploy.yml).
# deploy.yml reads these with a vars.* fallback, so a GitHub Variable also works.
SERVER_HOSTNAME         = @core
SERVER_USERNAME         = @core

# secrets.py reads the FILE at this path and pushes its CONTENTS as the secret
# SSH_PRIVATE_KEY. The path string itself is never pushed.
SSH_PRIVATE_KEY_PATH    = @core

# Bearer token for the check_local_vm_runner job (GitHub runners API).
VM_RUNNER_STATUS_PAT    = @core #github_pat_xxxx

# Cloudflare Access service token — used by the tunnel transport in deploy.yml.
CF_SERVICE_TOKEN_ID     = @core #xxxx.access
CF_SERVICE_TOKEN_SECRET = @core #xxxx.secret

# GHCR image cleanup (clean-containers.yml / bulk-delete-containers.yml). (Manually added by hand)
# DELETE_PACKAGES_TOKEN = @core

#@ local
# ════════════════════════════════════════════════════════════════════════════
#  LOCAL / DEV ONLY  →  never pushed, never leaves this machine
# ════════════════════════════════════════════════════════════════════════════

# Repo identity — secrets.py uses this to target the right GitHub repo.
REPO_OWNER              = @core
REPO_NAME               = ${APP_NAME}

# Convenience handles for local SSH, if you use them.
SSH_USER                = @core
SSH_HOST                = @core

# Local MySQL root password for `docker compose up` on your machine. On the
# server this is NOT taken from here — see the note in the response about where
# production gets MYSQL_ROOT_PASSWORD.
# MYSQL_ROOT_PASSWORD   = <db_password>
