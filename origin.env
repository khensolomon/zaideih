# origin.env
# cp origin.env .env
# In development, set DEBUG to True. In production, this should be False or unset.
DEBUG             = false # can be overridden by environment variable in production
APP_NAME          = <project>
APP_PORT          = 3010
# APP_HOST        = ?
ALLOWED_HOSTS     = *

# Storage Configuration
# <bucket> can be eg. /opt/bucket
STORAGE_ROOT      = /<bucket>/storage
MEDIA_ROOT        = /<bucket>/media
STORE_DIR         = /<bucket>/storage/<project>/store
CACHE_DIR         = /<bucket>/storage/<project>/cache

DB_NAME           = <project>
DB_USER           = <db_user> # Change "root" to your actual database username
DB_PWD            = <db_password>
DB_ROOT_PWD       = <db_password>
DB_HOST           = <db_host> # Change "db" to "localhost" for docker-compose
DB_PORT           = 3306
# DB backup and restore points to /docker-entrypoint-initdb.d in the MySQL container, which is mapped to ${DB_DIR} on the host
# ${STORAGE_ROOT}/${APP_NAME}/mysql
DB_DIR            = /<bucket>/storage/<project>/mysql

# NOTE: custom
REPO_OWNER        = khensolomon
REPO_NAME         = zaideih
# Get it from python manage.py generate_secret_key
# python -c 'import secrets; print(secrets.token_urlsafe(20))'
SECRET_KEY        = unique-and-secret-key-for-deployment
APP_SECRET_SHARED = unique-and-secret-shared-with-worker
# Bucket name and credentials for S3-compatible storage 
# (e.g., Google, MinIO, DigitalOcean Spaces) eg. storage.lethil.me or media on r2
STORAGE_BACKEND   = r2

# NOTE: GCS
GCS_BUCKETNAME    = storage.lethil.me
GCS_SECRET        = /opt/bucket/storage/access/gsaks.json

# NOTE: R2
R2_BUCKETNAME     = media
R2_ACCOUNT_ID     = <r2_account_id>
R2_ACCESS_ID      = <r2_access_key_id>
R2_SECRET_KEY     = <r2_secret_access_key>

# Where the Worker lives. Must be reachable from Django.
WORKER_URL        = "https://media.example.com"

# NOTE: special (MyOrdbok-specific)
# SPEECH_URL      = ?
# NLTK_DATA       = ?

# NOTE: development
# Deployment secrets — used by secrets.py only, never sent to Django
SERVER_HOSTNAME=<server_hostname>
SERVER_USER=<server_user>
SSH_PRIVATE_KEY_PATH=~/.ssh/prod_server
VM_RUNNER_STATUS_PAT=<vm_runner_status_pat> #github_pat_xxxx
CF_SERVICE_TOKEN_ID=<cf_service_token_id> #xxxx.access
CF_SERVICE_TOKEN_SECRET=<cf_service_token_secret> #xxxx.secret
# NOTE: local
SSH_USER = <ssh_user>
SSH_HOST = <ssh_host>
MYSQL_ROOT_PASSWORD=<db_password> # Only needed for local development, on production Github Actions will set this as an environment variable and it won't be used in the .env file.