# origin.env
# cp origin.env .env
# In development, set DEBUG to True. In production, this should be False or unset.
DEBUG         = false # can be overridden by environment variable in production
APP_NAME      = zaideih
APP_PORT      = 8000
# APP_HOST      = ?
ALLOWED_HOSTS = *

STORAGE_DIR   = /mnt/bucket/storage # /mnt/keep/storage
CACHE_DIR     = ~/dev/zaideih/cache/tmp # ~/dev/${APP_NAME}/cache/tmp
MEDIA_DIR     = /mnt/bucket/media # /storage/media

DB_NAME       = zaideih
DB_USER       = root
DB_PWD        = password
DB_ROOT_PWD   = password # Added for the MySQL Root user password
DB_HOST       = db # Change "localhost" to "db" for docker-compose
DB_PORT       = 3306
# DB backup and restore points to /docker-entrypoint-initdb.d in the MySQL container, which is mapped to ${DB_DIR} on the host
# ${STORAGE_DIR}/${APP_NAME}/mysql
DB_DIR        = /mnt/bucket/storage/zaideih/mysql

# NOTE: custom
GITHUB_REPOSITORY_OWNER = khensolomon
# Get it from python manage.py generate_secret_key
# python -c 'import secrets; print(secrets.token_urlsafe(20))'
SECRET_KEY    = unique-and-secret-key-for-deployment
# Buckket name and credentials for S3-compatible storage 
# (e.g., Google, MinIO, DigitalOcean Spaces)
BUCKETNAME    = storage.lethil.me
BUCKETCRED    = /mnt/bucket/storage/access/gsaks.json


# NOTE: development
SSH_USER      = <ssh_user>
SSH_HOST      = 192.168.122.253
GOOGLE_APPLICATION_CREDENTIALS = /mnt/bucket/storage/access/gsaks.json